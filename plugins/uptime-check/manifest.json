{
  "id": "uptime-check",
  "name": "Uptime Check",
  "version": "0.1.0",
  "description": "Ping a URL and report status code + round-trip latency. Quick 'is the site up?' check from inside the chat.",
  "author": "Ghast AI",
  "main": "main.mjs",
  "icon": "📡",
  "homepage": "https://github.com/Trapezohe/ghast-plugins/tree/main/plugins/uptime-check",
  "repository": "https://github.com/Trapezohe/ghast-plugins",
  "license": "MIT",
  "keywords": [
    "uptime",
    "monitor",
    "http",
    "ping"
  ],
  "engines": {
    "ghast": "^0.1.0"
  },
  "type": "tool",
  "permissions": [
    "tools:register"
  ],
  "activationEvents": [
    "onStartup"
  ],
  "contributes": {
    "tools": [
      {
        "id": "check_uptime",
        "name": "Check site uptime",
        "description": "Send an HTTP request and report status + latency."
      }
    ]
  }
}
