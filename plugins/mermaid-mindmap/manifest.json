{
  "id": "mermaid-mindmap",
  "name": "Mermaid Mind Map",
  "version": "0.1.0",
  "description": "Turn an outline or topic into a Mermaid mindmap diagram the chat can render as a tree.",
  "author": "Ghast AI",
  "main": "main.mjs",
  "icon": "🧠",
  "homepage": "https://github.com/Trapezohe/ghast-plugins/tree/main/plugins/mermaid-mindmap",
  "repository": "https://github.com/Trapezohe/ghast-plugins",
  "license": "MIT",
  "keywords": [
    "mindmap",
    "mermaid",
    "diagram",
    "outline"
  ],
  "engines": {
    "ghast": "^0.1.0"
  },
  "type": "transform",
  "permissions": [
    "tools:register"
  ],
  "activationEvents": [
    "onStartup"
  ],
  "contributes": {
    "tools": [
      {
        "id": "build_mindmap",
        "name": "Build a Mermaid mindmap",
        "description": "Convert a structured outline into a Mermaid mindmap code block."
      }
    ]
  }
}
