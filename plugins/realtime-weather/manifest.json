{
  "id": "realtime-weather",
  "name": "Realtime Weather",
  "version": "0.1.0",
  "description": "Current weather + a short forecast for any place name. Uses Open-Meteo — no API key, no signup.",
  "author": "Ghast AI",
  "main": "main.mjs",
  "icon": "🌦️",
  "homepage": "https://github.com/Trapezohe/ghast-plugins/tree/main/plugins/realtime-weather",
  "repository": "https://github.com/Trapezohe/ghast-plugins",
  "license": "MIT",
  "keywords": [
    "weather",
    "forecast",
    "open-meteo"
  ],
  "engines": {
    "ghast": "^0.1.0"
  },
  "type": "tool",
  "permissions": [
    "tools:register"
  ],
  "activationEvents": [
    "onStartup"
  ],
  "contributes": {
    "tools": [
      {
        "id": "get_weather",
        "name": "Get realtime weather",
        "description": "Current conditions + 24h forecast for a location name."
      }
    ]
  }
}
